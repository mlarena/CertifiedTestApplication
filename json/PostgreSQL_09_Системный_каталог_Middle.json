        { "Text": "Расширение для работы с классами объектов", "IsCorrect": false, "NumericValue": null }
      ]
    },
    {
      "Text": "Какая системная таблица показывает связи между объектами (например, какие столбцы используют типы данных)?",
      "Type": 1,
      "Order": 8,
      "Answers": [
        { "Text": "pg_depend", "IsCorrect": true, "NumericValue": null },
        { "Text": "pg_links", "IsCorrect": false, "NumericValue": null },
