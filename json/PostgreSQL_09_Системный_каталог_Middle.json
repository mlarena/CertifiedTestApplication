      ]
    },
    {
      "Text": "Как получить OID конкретной таблицы mytable?",
      "Type": 2,
      "Order": 4,
      "Answers": [
        { "Text": "SELECT oid FROM pg_class WHERE relname = 'mytable';", "IsCorrect": true, "NumericValue": null },
        { "Text": "SELECT pg_table_oid('mytable');", "IsCorrect": true, "NumericValue": null },
        { "Text": "SELECT oid FROM pg_tables WHERE tablename = 'mytable';", "IsCorrect": false, "NumericValue": null },
        { "Text": "SELECT object_id('mytable');", "IsCorrect": false, "NumericValue": null }
      ]
    },
    {
      "Text": "Какая колонка в pg_class показывает тип отношения (r=таблица, i=индекс, v=представление и т.д.)?",
      "Type": 1,
      "Order": 5,
      "Answers": [
        { "Text": "relkind", "IsCorrect": true, "NumericValue": null },
        { "Text": "reltype", "IsCorrect": false, "NumericValue": null },
        { "Text": "relkind_id", "IsCorrect": false, "NumericValue": null },
        { "Text": "rel_class", "IsCorrect": false, "NumericValue": null }
      ]
    },
    {
      "Text": "Как посмотреть все столбцы таблицы mytable через системные таблицы?",
      "Type": 1,
      "Order": 6,
      "Answers": [
        { "Text": "SELECT attname FROM pg_attribute WHERE attrelid = 'mytable'::regclass AND attnum > 0 AND NOT attisdropped;", "IsCorrect": true, "NumericValue": null },
        { "Text": "SELECT column_name FROM pg_columns WHERE table_name = 'mytable';", "IsCorrect": false, "NumericValue": null },
        { "Text": "SELECT * FROM pg_attribute WHERE relname = 'mytable';", "IsCorrect": false, "NumericValue": null },
        { "Text": "SELECT fields FROM pg_class WHERE relname = 'mytable';", "IsCorrect": false, "NumericValue": null }
      ]
    },
    {
      "Text": "Что такое regclass в контексте работы с pg_attribute?",
      "Type": 1,
      "Order": 7,
      "Answers": [
        { "Text": "Тип данных, представляющий OID отношения (таблицы) по имени", "IsCorrect": true, "NumericValue": null },
