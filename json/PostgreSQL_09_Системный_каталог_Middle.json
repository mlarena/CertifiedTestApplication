        { "Text": "pg_constraints", "IsCorrect": false, "NumericValue": null }
      ]
    },
    {
      "Text": "Как посмотреть количество записей (строк) в таблице через pg_class?",
      "Type": 1,
      "Order": 9,
      "Answers": [
        { "Text": "Через столбец reltuples в pg_class (приблизительное значение)", "IsCorrect": true, "NumericValue": null },
