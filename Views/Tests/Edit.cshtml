@model CertifiedTestApplication.Models.Entities.Test

<h2>Редактирование теста</h2>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body p-3">
                <h6 class="mb-3">Параметры теста</h6>
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AuthorId" />
                    
                    <div class="mb-2">
                        <label class="form-label small">Название</label>
                        <input asp-for="Title" class="form-control form-control-sm" required />
                    </div>
                    
                    <div class="mb-2">
                        <label class="form-label small">Категория</label>
                        <select asp-for="CategoryId" class="form-select form-select-sm" 
                                asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))"></select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small">Лимит времени (сек, 0 - нет)</label>
                        <input asp-for="TimeLimit" type="number" class="form-control form-control-sm" />
                    </div>

                    <div class="form-check mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox">
                        <label class="form-check-label small">Активен</label>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                        <a asp-action="Index" class="btn btn-link btn-sm text-secondary">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6>Вопросы</h6>
            <a asp-action="AddQuestion" asp-route-testId="@Model.Id" class="btn btn-success btn-sm">Добавить вопрос</a>
        </div>

        <div class="list-group shadow-sm">
            @foreach (var q in (IEnumerable<CertifiedTestApplication.Models.Entities.Question>)ViewBag.Questions)
            {
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-2">
                    <div>
                        <span class="badge bg-light text-dark border me-2">#@q.Order</span>
                        <span class="small">@q.Text</span>
                        <span class="badge bg-info ms-2" style="font-size: 0.7rem;">@q.Type</span>
                    </div>
                    <div>
                        <a asp-action="EditQuestion" asp-route-id="@q.Id" class="btn btn-outline-primary btn-sm py-0">Изм.</a>
                        <form asp-action="DeleteQuestion" asp-route-id="@q.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm py-0" onclick="return confirm('Удалить вопрос?')">Удалить</button>
                        </form>
                    </div>
                </div>
            }
            @if (!((IEnumerable<CertifiedTestApplication.Models.Entities.Question>)ViewBag.Questions).Any())
            {
                <div class="list-group-item text-center text-muted small">Вопросов пока нет</div>
            }
        </div>
    </div>
</div>
