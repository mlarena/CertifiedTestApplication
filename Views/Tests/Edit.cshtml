@model CertifiedTestApplication.Models.Entities.Test

@{
    var questions = ViewBag.Questions as IEnumerable<CertifiedTestApplication.Models.Entities.Question>;
}

<h5 class="mb-3">
    Редактирование теста
</h5>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Левая колонка: параметры теста -->
    <div class="col-lg-4">
        <div class="card border shadow-sm">
            <div class="card-header bg-white py-2">
                <h6 class="mb-0">Параметры теста</h6>
            </div>
            <div class="card-body p-3">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AuthorId" />

                    <div class="mb-3">
                        <label class="form-label small fw-medium">Название</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-medium">Категория</label>
                        <select asp-for="CategoryId" class="form-select"
                                asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))"></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-medium">Лимит времени (сек, 0 = нет)</label>
                        <input asp-for="TimeLimit" type="number" class="form-control" min="0" />
                    </div>

                    <div class="form-check mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox">
                        <label class="form-check-label small">Активен (доступен для прохождения)</label>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="CanReturnToQuestion" class="form-check-input" type="checkbox">
                        <label class="form-check-label small">Разрешить возврат к вопросам</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Назад</a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline ms-auto">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Удалить тест «@Model.Title»? Все вопросы и ответы будут удалены.')">Удалить тест</button>
                        </form>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Правая колонка: вопросы -->
    <div class="col-lg-8">
        <div class="card border shadow-sm">
            <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Вопросы</h6>
                <div class="d-flex gap-2 align-items-center">
                    <span class="badge bg-secondary">@(questions?.Count() ?? 0)</span>
                    <a asp-action="AddQuestion" asp-route-testId="@Model.Id" class="btn btn-success btn-sm">+ Добавить</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (questions != null && questions.Any())
                {
                    <div class="list-group list-group-flush" id="questionsList">
                        @foreach (var q in questions)
                        {
                            <div class="list-group-item px-3 py-2 question-item" data-question-id="@q.Id" draggable="true">
                                <div class="d-flex align-items-center gap-2">
                                    <!-- Drag handle -->
                                    <div class="drag-handle text-muted" style="cursor: grab; font-size: 1.2rem; user-select: none;">
                                        &#9776;
                                    </div>

                                    <!-- Порядковый номер -->
                                    <span class="badge bg-light text-dark border flex-shrink-0" style="min-width: 2rem;">
                                        #@q.Order
                                    </span>

                                    <!-- Текст вопроса -->
                                    <div class="flex-grow-1 text-truncate">
                                        <span class="small">@q.Text</span>
                                    </div>

                                    <!-- Тип -->
                                    <span class="badge bg-info flex-shrink-0" style="font-size: 0.7rem;">
                                        @switch (q.Type)
                                        {
                                            case CertifiedTestApplication.Models.Entities.QuestionType.Single:
                                                @:Один
                                                break;
                                            case CertifiedTestApplication.Models.Entities.QuestionType.Multiple:
                                                @:Несколько
                                                break;
                                            case CertifiedTestApplication.Models.Entities.QuestionType.Numeric:
                                                @:Число
                                                break;
                                        }
                                    </span>

                                    <!-- Ответы (кол-во) -->
                                    @{
                                        var answerCount = q.Answers?.Count ?? 0;
                                    }
                                    <span class="badge @(answerCount > 0 ? "bg-success" : "bg-warning text-dark") flex-shrink-0">
                                        @answerCount ответов
                                    </span>

                                    <!-- Действия -->
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <a asp-action="EditQuestion" asp-route-id="@q.Id" class="btn btn-outline-primary btn-sm py-0 px-1">
                                            Изм.
                                        </a>
                                        <form asp-action="DeleteQuestion" asp-route-id="@q.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1"
                                                    onclick="return confirm('Удалить вопрос и все его ответы?')">Удал.</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted small">
                        Вопросов пока нет. Нажмите "Добавить" чтобы создать первый вопрос.
                    </div>
                }
            </div>
        </div>

        @if (questions != null && questions.Any())
        {
            <div class="mt-2 text-muted small">
                Перетаскивайте вопросы за иконку &#9776; для изменения порядка. Порядок сохраняется автоматически.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const list = document.getElementById('questionsList');
            if (!list) return;

            let dragItem = null;

            list.addEventListener('dragstart', function (e) {
                const item = e.target.closest('.question-item');
                if (!item) return;
                dragItem = item;
                item.style.opacity = '0.4';
                e.dataTransfer.effectAllowed = 'move';
            });

            list.addEventListener('dragend', function (e) {
                const item = e.target.closest('.question-item');
                if (item) item.style.opacity = '1';
                dragItem = null;
                list.querySelectorAll('.question-item').forEach(i => i.style.borderTop = '');
            });

            list.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                const target = e.target.closest('.question-item');
                if (target && target !== dragItem) {
                    target.style.borderTop = '2px solid #0d6efd';
                }
            });

            list.addEventListener('dragleave', function (e) {
                const target = e.target.closest('.question-item');
                if (target) target.style.borderTop = '';
            });

            list.addEventListener('drop', function (e) {
                e.preventDefault();
                const target = e.target.closest('.question-item');
                if (!target || !dragItem || target === dragItem) return;

                const allItems = [...list.querySelectorAll('.question-item')];
                const dragIndex = allItems.indexOf(dragItem);
                const dropIndex = allItems.indexOf(target);

                if (dragIndex < dropIndex) {
                    target.after(dragItem);
                } else {
                    target.before(dragItem);
                }

                updateOrder();
            });

            function updateOrder() {
                const items = list.querySelectorAll('.question-item');
                const ids = [];
                items.forEach((item, index) => {
                    item.querySelector('.badge.bg-light').textContent = '#' + (index + 1);
                    ids.push(item.dataset.questionId);
                });

                fetch('@Url.Action("UpdateQuestionOrder")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: 'testId=@Model.Id&' + ids.map(id => 'questionIds=' + id).join('&')
                });
            }
        });
    </script>
}
