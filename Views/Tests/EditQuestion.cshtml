@model CertifiedTestApplication.Models.Entities.Question

<h2>Редактирование вопроса</h2>

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-body p-3">
                <h6 class="mb-3">Параметры вопроса</h6>
                <form asp-action="EditQuestion" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TestId" />
                    <input type="hidden" asp-for="ImagePath" />
                    
                    <div class="mb-2">
                        <label class="form-label small">Текст вопроса</label>
                        <textarea asp-for="Text" class="form-control form-control-sm" rows="3" required></textarea>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small">Тип вопроса</label>
                        <select asp-for="Type" class="form-select form-select-sm" 
                                asp-items="Html.GetEnumSelectList<CertifiedTestApplication.Models.Entities.QuestionType>()"></select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small">Порядок</label>
                        <input asp-for="Order" type="number" class="form-control form-control-sm" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImagePath" class="img-thumbnail" style="max-height: 150px;" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label small">Заменить изображение</label>
                        <input type="file" name="image" class="form-control form-control-sm" accept="image/*" />
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary btn-sm">Сохранить изменения</button>
                        <a asp-action="Edit" asp-route-id="@Model.TestId" class="btn btn-link btn-sm text-secondary">К тесту</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <h6>Варианты ответов</h6>
        
        <div class="card shadow-sm mb-3">
            <div class="card-body p-2">
                <form asp-action="AddAnswer" method="post" class="row g-2 align-items-end">
                    <input type="hidden" name="questionId" value="@Model.Id" />
                    <div class="col-7">
                        <label class="form-label small mb-0">Текст ответа / Значение</label>
                        <input name="text" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-3">
                        <div class="form-check mb-1">
                            <input name="isCorrect" class="form-check-input" type="checkbox" value="true">
                            <label class="form-check-label small">Верный</label>
                        </div>
                    </div>
                    <div class="col-2">
                        <button type="submit" class="btn btn-success btn-sm w-100">Add</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-sm table-hover border">
                <thead class="table-light">
                    <tr>
                        <th>Текст</th>
                        <th class="text-center">Верный</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in (IEnumerable<CertifiedTestApplication.Models.Entities.Answer>)ViewBag.Answers)
                    {
                        <tr>
                            <td class="small">@a.Text</td>
                            <td class="text-center">
                                @if (a.IsCorrect) { <span class="text-success">✔</span> }
                            </td>
                            <td class="text-end">
                                <form asp-action="DeleteAnswer" asp-route-id="@a.Id" method="post" style="display:inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm py-0">Удалить</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
