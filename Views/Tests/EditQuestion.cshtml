@model CertifiedTestApplication.Models.Entities.Question

@{
    var answers = ViewBag.Answers as IEnumerable<CertifiedTestApplication.Models.Entities.Answer>;
    var isNumeric = Model.Type == CertifiedTestApplication.Models.Entities.QuestionType.Numeric;
    var isMultiple = Model.Type == CertifiedTestApplication.Models.Entities.QuestionType.Multiple;
}

<h5 class="mb-3">
    <a asp-action="Edit" asp-route-id="@Model.TestId" class="text-decoration-none">@Model.Test?.Title</a>
    <span class="text-muted mx-2">/</span>
    Вопрос #@Model.Order
</h5>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Левая колонка: параметры вопроса -->
    <div class="col-lg-5">
        <div class="card border shadow-sm">
            <div class="card-header bg-white py-2">
                <h6 class="mb-0">Параметры вопроса</h6>
            </div>
            <div class="card-body p-3">
                <form asp-action="EditQuestion" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TestId" />
                    <input type="hidden" asp-for="ImagePath" />

                    <div class="mb-3">
                        <label class="form-label small fw-medium">Текст вопроса</label>
                        <textarea asp-for="Text" class="form-control" rows="4" required></textarea>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-medium">Тип вопроса</label>
                            <select asp-for="Type" class="form-select"
                                    asp-items="Html.GetEnumSelectList<CertifiedTestApplication.Models.Entities.QuestionType>()"></select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-medium">Порядок</label>
                            <input asp-for="Order" type="number" class="form-control" min="1" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mb-3">
                            <label class="form-label small fw-medium">Текущее изображение</label>
                            <div class="text-center p-2 bg-light rounded">
                                <img src="@Model.ImagePath" class="img-fluid rounded" style="max-height: 200px;" />
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label small fw-medium">@(string.IsNullOrEmpty(Model.ImagePath) ? "Загрузить изображение" : "Заменить изображение")</label>
                        <input type="file" name="image" class="form-control" accept="image/*" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Сохранить</button>
                        <a asp-action="Edit" asp-route-id="@Model.TestId" class="btn btn-outline-secondary">К тесту</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Правая колонка: ответы -->
    <div class="col-lg-7">
        <div class="card border shadow-sm">
            <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Варианты ответов</h6>
                <span class="badge bg-secondary">@(answers?.Count() ?? 0)</span>
            </div>
            <div class="card-body p-0">
                <!-- Форма добавления ответа -->
                <div class="p-3 border-bottom bg-light">
                    <form asp-action="AddAnswer" method="post" class="row g-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="questionId" value="@Model.Id" />
                        <div class="@(isNumeric ? "col-md-5" : "col-md-7")">
                            <label class="form-label small mb-1">@(isNumeric ? "Числовое значение" : "Текст ответа")</label>
                            <input name="text" class="form-control form-control-sm" required
                                   placeholder="@(isNumeric ? "напр. 24.5" : "Введите текст ответа")" />
                        </div>
                        @if (isNumeric)
                        {
                            <div class="col-md-2">
                                <label class="form-label small mb-1">Эталон</label>
                                <input name="numericValue" type="number" step="any" class="form-control form-control-sm" />
                            </div>
                        }
                        <div class="col-md-2">
                            <div class="form-check">
                                <input name="isCorrect" class="form-check-input" type="checkbox" value="true" id="addCorrectCheck">
                                <label class="form-check-label small" for="addCorrectCheck">Верный</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-success btn-sm w-100">
                                <span class="d-none d-md-inline">Добавить</span>
                                <span class="d-md-none">+</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Список ответов -->
                @if (answers != null && answers.Any())
                {
                    <div class="list-group list-group-flush" id="answersList">
                        @foreach (var a in answers)
                        {
                            <div class="list-group-item px-3 py-2" data-answer-id="@a.Id">
                                <div class="d-flex align-items-center gap-2">
                                    <!-- Чекбокс верного ответа -->
                                    <form asp-action="ToggleAnswerCorrect" method="post" class="flex-shrink-0">
                                        <input type="hidden" name="id" value="@a.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm p-0 border-0 bg-transparent" title="@(a.IsCorrect ? "Верный ответ" : "Неверный ответ")">
                                            @if (a.IsCorrect)
                                            {
                                                <span class="badge bg-success fs-6">✔</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark border fs-6">○</span>
                                            }
                                        </button>
                                    </form>

                                    <!-- Текст ответа (inline редактирование) -->
                                    <div class="flex-grow-1">
                                        <span class="answer-text small" id="text-@a.Id">@a.Text</span>
                                        @if (a.NumericValue.HasValue)
                                        {
                                            <span class="badge bg-info ms-1">= @a.NumericValue</span>
                                        }
                                    </div>

                                    <!-- Кнопки действий -->
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <button type="button" class="btn btn-outline-primary btn-sm py-0 px-1"
                                                onclick="editAnswer('@a.Id', '@a.Text.Replace("'", "\\'")', @(a.IsCorrect.ToString().ToLower()), @(a.NumericValue?.ToString() ?? "null"))">
                                            Изм.
                                        </button>
                                        <form asp-action="DeleteAnswer" asp-route-id="@a.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1"
                                                    onclick="return confirm('Удалить ответ?')">Удал.</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted small">
                        Ответов пока нет. Добавьте хотя бы один вариант ответа.
                    </div>
                }
            </div>
        </div>

        <!-- Подсказка по типу вопроса -->
        <div class="mt-3">
            @if (isNumeric)
            {
                <div class="alert alert-info py-2 small mb-0">
                    <strong>Числовой вопрос:</strong> в поле "Текст ответа" введите число. Пользователь должен ввести точное значение.
                </div>
            }
            else if (Model.Type == CertifiedTestApplication.Models.Entities.QuestionType.Single)
            {
                <div class="alert alert-info py-2 small mb-0">
                    <strong>Одиночный выбор:</strong> добавьте варианты ответов и пометьте верный (клик по значку слева).
                </div>
            }
            else
            {
                <div class="alert alert-info py-2 small mb-0">
                    <strong>Множественный выбор:</strong> пометьте все верные ответы (клик по значку слева).
                </div>
            }
        </div>
    </div>
</div>

<!-- Модальное окно редактирования ответа -->
<div class="modal fade" id="editAnswerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditAnswer" method="post">
                <input type="hidden" id="editAnswerId" name="Id" />
                @Html.AntiForgeryToken()
                <div class="modal-header py-2">
                    <h6 class="modal-title">Редактирование ответа</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Текст ответа</label>
                        <input type="text" id="editAnswerText" name="Text" class="form-control" required />
                    </div>
                    <div class="mb-3" id="editNumericGroup" style="display:none;">
                        <label class="form-label small fw-medium">Числовое значение (эталон)</label>
                        <input type="number" step="any" id="editNumericValue" name="NumericValue" class="form-control" />
                    </div>
                    <div class="form-check">
                        <input type="checkbox" id="editAnswerCorrect" name="IsCorrect" class="form-check-input" value="true">
                        <label class="form-check-label" for="editAnswerCorrect">Верный ответ</label>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editAnswer(id, text, isCorrect, numericValue) {
            document.getElementById('editAnswerId').value = id;
            document.getElementById('editAnswerText').value = text;
            document.getElementById('editAnswerCorrect').checked = isCorrect;

            var numericGroup = document.getElementById('editNumericGroup');
            @if (isNumeric)
            {
                <text>
                numericGroup.style.display = 'block';
                document.getElementById('editNumericValue').value = numericValue || '';
                </text>
            }

            new bootstrap.Modal(document.getElementById('editAnswerModal')).show();
        }
    </script>
}
