@model CertifiedTestApplication.Models.Entities.TestAttempt

<div class="container mt-5 text-center" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
            </div>
            <h2 class="mb-3">Тест завершен!</h2>
            <p class="text-muted mb-4">Вы прошли тест: <strong>@Model.Test?.Title</strong></p>
            
            <div class="display-4 mb-2 @(Model.Score >= 80 ? "text-success" : "text-danger")">
                @Model.Score%
            </div>
            <p class="small text-muted mb-4">Ваш результат</p>

            <hr />

            <div class="d-grid gap-2 mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm">Вернуться на главную</a>
            </div>
        </div>
    </div>
</div>
