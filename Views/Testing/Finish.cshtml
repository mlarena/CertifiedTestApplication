@model CertifiedTestApplication.Models.Entities.TestAttempt
@using CertifiedTestApplication.Models.Entities
@{
    var questionResults = ViewBag.QuestionResults as IEnumerable<CertifiedTestApplication.Models.ViewModels.QuestionResultDetail>;
    var correctCount = (int)ViewBag.CorrectCount;
    var totalCount = (int)ViewBag.TotalCount;
    var forceFinish = ViewBag.ForceFinish as bool? ?? false;
}

<style>
    .result-question { border-left: 4px solid #dee2e6; }
    .result-question.correct { border-left-color: #198754; }
    .result-question.incorrect { border-left-color: #dc3545; }
    .ra { padding: 5px 10px; border-radius: 4px; margin-bottom: 3px; border: 1px solid transparent; font-size: 0.9rem; }
    .ra-correct-selected { background-color: #d1e7dd; border-color: #badbcc; color: #0f5132; }
    .ra-incorrect-selected { background-color: #f8d7da; border-color: #f5c2c7; color: #842029; }
    .ra-correct-not-selected { background-color: #d1e7dd; border-color: #badbcc; color: #0f5132; opacity: 0.7; }
    .ra-neutral { background-color: #f8f9fa; color: #6c757d; }
</style>

<div class="container mt-4" style="max-width: 850px;">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 text-center">
            <div class="mb-3">
                @if (Model.Score >= 80)
                {
                    <span style="font-size: 4rem;">&#127942;</span>
                }
                else
                {
                    <span style="font-size: 4rem;">&#128170;</span>
                }
            </div>
            <h2 class="mb-2">Тест завершён!</h2>
            <p class="text-muted mb-3">@Model.Test?.Title</p>

            <div class="d-inline-flex align-items-center gap-4 p-3 bg-light rounded-3">
                <div>
                    <div class="display-4 fw-bold @(Model.Score >= 80 ? "text-success" : "text-danger")">
                        @Model.Score%
                    </div>
                    <div class="small text-muted">Результат</div>
                </div>
                <div class="vr"></div>
                <div>
                    <div class="display-4 fw-bold">
                        @correctCount <span class="text-muted h4">/ @totalCount</span>
                    </div>
                    <div class="small text-muted">Правильных ответов</div>
                </div>
            </div>

            <div class="mt-3">
                @if (Model.Score >= 80)
                {
                    <span class="badge bg-success fs-6 px-3 py-2">Тест пройден</span>
                }
                else
                {
                    <span class="badge bg-danger fs-6 px-3 py-2">Тест не пройден</span>
                }
            </div>

            <div class="mt-3 small text-muted">
                Время прохождения:
                @{
                    var duration = Model.FinishedAt.HasValue
                        ? Model.FinishedAt.Value - Model.StartedAt
                        : TimeSpan.Zero;
                }
                @((int)duration.TotalMinutes) мин @duration.Seconds сек
            </div>
            @if (forceFinish)
            {
                <div class="mt-2">
                    <span class="badge bg-warning text-dark">Время вышло. Тест завершён автоматически.</span>
                </div>
            }
        </div>
    </div>

    <h5 class="mb-3">Разбор ответов</h5>

    @if (questionResults != null)
    {
        int qIndex = 0;
        @foreach (var qr in questionResults)
        {
            qIndex++;

            var userSelectedIds = qr.UserAnswers
                .Where(ua => ua.SelectedAnswerId.HasValue)
                .Select(ua => ua.SelectedAnswerId!.Value)
                .ToHashSet();

            var correctIds = qr.CorrectAnswers.Select(a => a.Id).ToHashSet();

            var userRawValue = qr.UserAnswers.FirstOrDefault()?.RawValue;

            <div class="card border-0 shadow-sm mb-3 result-question @(qr.IsCorrect ? "correct" : "incorrect")">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="d-flex align-items-start gap-2">
                            <span class="badge @(qr.IsCorrect ? "bg-success" : "bg-danger") flex-shrink-0 mt-1">
                                @(qr.IsCorrect ? "✔" : "✘")
                            </span>
                            <div>
                                <span class="small text-muted">Вопрос @qIndex из @totalCount</span>
                                <div class="fw-medium">@qr.Question.Text</div>
                            </div>
                        </div>
                        <span class="badge bg-light text-dark border flex-shrink-0">
                            @switch (qr.Question.Type)
                            {
                                case QuestionType.Single:
                                    @:Один ответ
                                    break;
                                case QuestionType.Multiple:
                                    @:Несколько ответов
                                    break;
                                case QuestionType.Numeric:
                                    @:Число
                                    break;
                            }
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(qr.Question.ImagePath))
                    {
                        <div class="mb-2">
                            <img src="@qr.Question.ImagePath" class="img-fluid rounded border" style="max-height: 200px;" />
                        </div>
                    }

                    @if (qr.Question.Type == QuestionType.Numeric)
                    {
                        <div class="small mt-2">
                            @if (!string.IsNullOrEmpty(userRawValue))
                            {
                                <span class="text-muted">Ваш ответ:</span>
                                <strong class="@(qr.IsCorrect ? "text-success" : "text-danger") ms-1">@userRawValue</strong>
                            }
                            else
                            {
                                <span class="text-muted">Ответ не дан</span>
                            }

                            @if (!qr.IsCorrect && qr.AllAnswers.Where(a => a.IsCorrect).Any())
                            {
                                <span class="text-muted ms-3">Правильный ответ:</span>
                                <strong class="text-success ms-1">
                                    @string.Join(", ", qr.AllAnswers.Where(a => a.IsCorrect).Select(a => a.Text))
                                </strong>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mt-2">
                            @foreach (var a in qr.AllAnswers)
                            {
                                var isCorrectAnswer = a.IsCorrect;
                                var isSelected = userSelectedIds.Contains(a.Id);
                                var cssClass = (isCorrectAnswer && isSelected) ? "ra-correct-selected"
                                    : (isSelected && !isCorrectAnswer) ? "ra-incorrect-selected"
                                    : (isCorrectAnswer && !isSelected) ? "ra-correct-not-selected"
                                    : "ra-neutral";

                                <div class="ra @cssClass">
                                    @if (isSelected && isCorrectAnswer)
                                    {
                                        <span class="me-1">&#10004;</span>
                                    }
                                    else if (isSelected && !isCorrectAnswer)
                                    {
                                        <span class="me-1">&#10008;</span>
                                    }
                                    else if (isCorrectAnswer)
                                    {
                                        <span class="me-1 text-success">&#8594;</span>
                                    }
                                    else
                                    {
                                        <span class="me-1">&nbsp;&nbsp;&nbsp;</span>
                                    }
                                    @a.Text
                                </div>
                            }
                        </div>

                        @if (!userSelectedIds.Any())
                        {
                            <div class="small text-muted mt-1">Ответ не дан</div>
                        }
                    }
                </div>
            </div>
        }
    }

    <div class="d-flex justify-content-between mt-4 mb-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">На главную</a>
        <a asp-controller="Reports" asp-action="MyResults" class="btn btn-outline-primary">Мои результаты</a>
    </div>
</div>
