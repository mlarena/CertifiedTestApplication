@model IEnumerable<CertifiedTestApplication.Models.Entities.Test>
@{
    ViewData["Title"] = "Доступные тесты";
    var categories = Model.Where(t => t.Category != null).Select(t => t.Category!).DistinctBy(c => c.Id).OrderBy(c => c.Name).ToList();
    var userId = Guid.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Система технического тестирования</h5>
</div>

@if (categories.Any())
{
    <div class="mb-3 d-flex flex-wrap gap-2">
        <button class="btn btn-sm btn-primary category-btn active" data-category="all">Все</button>
        @foreach (var cat in categories)
        {
            <button class="btn btn-sm btn-outline-secondary category-btn" data-category="@cat.Id">@cat.Name</button>
        }
    </div>
}

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3" id="testsContainer">
    @foreach (var test in Model)
    {
        var questionCount = test.Questions?.Count ?? 0;
        var lastAttempt = test.Attempts?
            .Where(a => a.UserId == userId)
            .OrderByDescending(a => a.StartedAt)
            .FirstOrDefault();
        <div class="col test-card" data-category="@test.CategoryId">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle small">@test.Category?.Name</span>
                        @if (test.TimeLimit > 0)
                        {
                            <span class="text-muted small">&#9202; @(test.TimeLimit / 60) мин</span>
                        }
                    </div>
                    <h6 class="card-title mb-1">@test.Title</h6>
                    <p class="card-text small text-muted mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@test.Description</p>

                    <div class="d-flex align-items-center gap-3 mb-2">
                        <span class="small text-muted">
                            <span class="fw-medium">@questionCount</span> вопросов
                        </span>
                        @if (lastAttempt != null && lastAttempt.Status == CertifiedTestApplication.Models.Entities.AttemptStatus.Completed)
                        {
                            <span class="small @(lastAttempt.Score >= 80 ? "text-success" : "text-danger")">
                                @lastAttempt.Score%
                            </span>
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0 pb-2 px-3">
                    <a asp-controller="Testing" asp-action="Start" asp-route-testId="@test.Id"
                       class="btn @(lastAttempt != null && lastAttempt.Status == CertifiedTestApplication.Models.Entities.AttemptStatus.InProgress ? "btn-warning" : "btn-outline-primary") btn-sm w-100 py-1">
                        @if (lastAttempt != null && lastAttempt.Status == CertifiedTestApplication.Models.Entities.AttemptStatus.InProgress)
                        {
                            @:Продолжить
                        }
                        else
                        {
                            @:Начать тест
                        }
                    </a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">На данный момент нет активных тестов.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.category-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.category-btn').forEach(b => {
                    b.classList.remove('active');
                    b.classList.replace('btn-primary', 'btn-outline-secondary');
                });
                this.classList.add('active');
                this.classList.replace('btn-outline-secondary', 'btn-primary');

                const cat = this.dataset.category;
                document.querySelectorAll('.test-card').forEach(card => {
                    if (cat === 'all' || card.dataset.category === cat) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    </script>
}
