@model dynamic

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Категории тестов</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show small py-2" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body p-3">
                <h6 class="card-title mb-3">Добавить категорию</h6>
                <form asp-action="Create" method="post">
                    <div class="input-group input-group-sm">
                        <input name="name" class="form-control" placeholder="Название категории" required />
                        <button class="btn btn-primary" type="submit">Добавить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="table-responsive">
            <table class="table table-sm table-hover border">
                <thead class="table-light">
                    <tr>
                        <th>Название</th>
                        <th class="text-center">Кол-во тестов</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Category.Name</td>
                            <td class="text-center">@item.TestsCount</td>
                            <td class="text-end">
                                @if (item.TestsCount == 0)
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Category.Id" method="post" style="display:inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm py-0" 
                                                onclick="return confirm('Удалить категорию?')">Удалить</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Нельзя удалить</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
