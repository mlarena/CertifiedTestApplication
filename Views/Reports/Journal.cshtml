@model IEnumerable<CertifiedTestApplication.Models.Entities.TestAttempt>

<h2>Журнал тестирования</h2>

<div class="table-responsive mt-3">
    <table class="table table-sm table-hover border">
        <thead class="table-light">
            <tr>
                <th>Пользователь</th>
                <th>Тест</th>
                <th>Дата</th>
                <th>Балл</th>
                <th>Результат</th>
                <th class="text-end">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.User?.FullName <br/><small class="text-muted">@item.User?.Login</small></td>
                    <td>@item.Test?.Title</td>
                    <td>@item.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td><strong>@item.Score%</strong></td>
                    <td>
                        @if (item.Score >= 80) { <span class="badge bg-success">Сдал</span> }
                        else { <span class="badge bg-danger">Не сдал</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm py-0">Детали</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
