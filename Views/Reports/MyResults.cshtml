@model IEnumerable<CertifiedTestApplication.Models.Entities.TestAttempt>

<h2>Мои результаты</h2>

<div class="table-responsive mt-3">
    <table class="table table-sm table-hover border">
        <thead class="table-light">
            <tr>
                <th>Тест</th>
                <th>Дата</th>
                <th>Результат</th>
                <th>Статус</th>
                <th class="text-end">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Test?.Title</td>
                    <td>@item.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (item.Status == CertifiedTestApplication.Models.Entities.AttemptStatus.Completed)
                        {
                            <strong class="@(item.Score >= 80 ? "text-success" : "text-danger")">@item.Score%</strong>
                        }
                        else
                        {
                            <span class="text-muted">В процессе</span>
                        }
                    </td>
                    <td>
                        @if (item.Status == CertifiedTestApplication.Models.Entities.AttemptStatus.Completed)
                        {
                            if (item.Score >= 80) { <span class="badge bg-success">Сдал</span> }
                            else { <span class="badge bg-danger">Не сдал</span> }
                        }
                    </td>
                    <td class="text-end">
                        @if (item.Status == CertifiedTestApplication.Models.Entities.AttemptStatus.Completed)
                        {
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm py-0">Разбор ошибок</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted">Вы еще не проходили тесты</td></tr>
            }
        </tbody>
    </table>
</div>
