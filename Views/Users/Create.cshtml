@model CertifiedTestApplication.Models.Entities.User

<h2>Создание пользователя</h2>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            
            <div class="mb-2">
                <label class="form-label small">Логин</label>
                <input asp-for="Login" class="form-control form-control-sm" required />
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>

            <div class="mb-2">
                <label class="form-label small">Пароль</label>
                <input name="password" type="password" class="form-control form-control-sm" required />
            </div>

            <div class="mb-2">
                <label class="form-label small">ФИО</label>
                <input asp-for="FullName" class="form-control form-control-sm" required />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-2">
                <label class="form-label small">Роль</label>
                <select asp-for="RoleId" class="form-select form-select-sm" 
                        asp-items="@(new SelectList(ViewBag.Roles, "Id", "Name"))"></select>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary btn-sm">Сохранить</button>
                <a asp-action="Index" class="btn btn-link btn-sm text-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>
